---
import Base from '../layouts/Base.astro';
---

<Base title="Page Not Found">
  <main class="max-w-xl mx-auto px-4 py-24 text-center">
    <div class="text-6xl font-bold text-slate-200 mb-4">404</div>
    <h1 class="text-2xl font-semibold text-slate-800 mb-2">Page not found</h1>
    <p class="text-slate-500 mb-8">
      Sorry, the page you're looking for doesn't exist.
    </p>
    <a
      href="/"
      class="inline-block px-5 py-2 bg-primary text-white rounded hover:bg-primary-dark transition-colors"
    >
      Go home
    </a>
  </main>
</Base>
