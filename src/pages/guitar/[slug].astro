---
import Base from '../../layouts/Base.astro';
import AuthorSidebar from '../../components/AuthorSidebar.astro';
import TagBadge from '../../components/TagBadge.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const songs = await getCollection('guitar');
  return songs.map((post) => ({ params: { slug: post.id }, props: { post } }));
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<Base title={post.data.title} description={post.data.excerpt}>
  <div class="max-w-5xl mx-auto px-4 py-8">
    <h1 class="text-2xl md:text-3xl font-bold text-slate-800 mb-2">
      {post.data.title}
    </h1>
    {post.data.excerpt && (
      <p class="text-slate-500 mb-3">{post.data.excerpt}</p>
    )}
    <div class="flex flex-wrap gap-1 mb-8">
      {post.data.tags.map((tag) => <TagBadge tag={tag} />)}
    </div>

    <div class="flex flex-col lg:flex-row gap-10">
      <article class="min-w-0 flex-1 prose prose-slate max-w-none prose-pre:font-mono prose-pre:text-sm">
        <Content />
      </article>
      <aside class="lg:w-64 shrink-0">
        <AuthorSidebar />
      </aside>
    </div>
  </div>
</Base>
