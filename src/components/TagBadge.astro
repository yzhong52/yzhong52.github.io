---
interface Props {
  tag: string;
}
const { tag } = Astro.props;
const slug = tag.toLowerCase().replace(/\s+/g, '-');
---

<a
  href={`/tags/#${slug}`}
  class="inline-block px-2 py-0.5 text-xs font-medium bg-slate-100 text-slate-600 rounded hover:bg-primary hover:text-white transition-colors"
>
  {tag}
</a>
